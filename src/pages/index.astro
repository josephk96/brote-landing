---
import "@fontsource-variable/inter";
import "~/styles/index.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import homeViewImage from "../assets/home-view.png";
import appStoreDownload from "../assets/app-store-download.svg";

const { site } = Astro;

const   title = "Brote - Coffee Brew Journal App for iPhone & iPad";
const description =
  "Stop forgetting what worked. Brote is a free pour-over, AeroPress, and espresso brew journal for iPhone and iPad. Log dose, grind size, water temperature, and brew time. Manage your bean collection. Dial in every cup.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Brote",
  operatingSystem: "iOS, iPadOS",
  applicationCategory: "FoodAndDrinkApplication",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  description:
    "A specialty coffee brewing journal for iPhone and iPad. Log brew parameters (dose, water, temperature, time, grind size), manage your bean collection, organize equipment, and rate brews with tasting notes. Supports pour-over (V60, Hario Switch), AeroPress, espresso, immersion, and custom brew methods. All data stored locally — no account required.",
  url: site,
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="pt-8 md:pt-16">
    <div class="mx-auto grid w-full max-w-7xl gap-12 px-6 md:grid-cols-2">
      <div>
        <h1 class="mb-8 font-bold text-6xl md:text-8xl">Brote</h1>

        <h2 class="mb-6 font-medium text-3xl md:text-4xl">Brew better cups</h2>

        <p class="mb-8 max-w-lg leading-relaxed text-lg md:mb-12 md:text-xl">
          A clean, native SwiftUI coffee brew log for people who care about taste.
        </p>

        <a href="https://testflight.apple.com/join/ee7Nb7DK">
          <Image
            src={appStoreDownload}
            alt="Download Brote on the App Store"
            class="h-auto w-48"
          />
        </a>
      </div>

      <div class="flex justify-end md:mt-20">
        <Image
          src={homeViewImage}
          alt="Brote app brew list showing coffee brews grouped by date with ratings"
          class="h-auto w-80 md:w-96"
        />
      </div>
    </div>
  </section>

  <!--<div class="mt-auto py-6 px-6 text-sm">-->
  <!--  <a href="/privacy">Privacy Policy</a>-->
  <!--</div>-->
</BaseLayout>
