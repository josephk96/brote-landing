---
import "@fontsource-variable/inter";
import "~/styles/index.css";
import BaseLayout from "../layouts/BaseLayout.astro";


const { generator, site } = Astro;
const image = new URL("social.jpg", site);

const description =
  "Brote is a clean coffee brew log for people who care about taste and process.";
---

<!doctype html>
<BaseLayout>
      <div class="pt-40">
        <h1 class="mb-10 font-bold text-6xl md:text-8xl">Brote</h1>

        <h2 class="mb-6 font-medium text-3xl md:text-4xl">Brew better cups</h2>

        <p class="max-w-xl leading-relaxed text-lg md:text-xl">
          A clean, native SwiftUI coffee brew log for people who care about
          taste.
        </p>
      </div>

      <div class="flex flex-1 items-end justify-end pr-40">
        <img
          src="/screenshot.png"
          alt="Brote app screenshot"
          class="max-w-xs md:max-w-sm"
        />
      </div>

      <div class="mt-10 text-sm">
        <a href="/privacy"> Privacy Policy </a>
      </div>
</BaseLayout>
