---
import "@fontsource-variable/inter";
import "~/styles/index.css";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<!doctype html>
<BaseLayout
  title="Support - Brote"
  description="Get help with Brote, the specialty coffee brew journal for iPhone and iPad. FAQs, getting started guide, and contact information."
>
  <div class="max-w-3xl pt-20">

    <h1 class="mb-12 font-bold text-6xl md:text-7xl">
      Support
    </h1>

    <h2 class="mt-16 mb-4 text-lg font-semibold uppercase tracking-wide">
      Getting Started
    </h2>

    <p class="mb-10 text-base leading-relaxed">
      Brote is a brew log for tracking your coffee recipes. Add a brew, select your beans, dial in your ratio and time, and take notes on how it tasted. Your data stays on your device.
    </p>

    <h2 class="mt-12 mb-4 text-lg font-semibold uppercase tracking-wide">
      Common Questions
    </h2>

    <p class="mb-10 text-base leading-relaxed">
      <strong>Where is my data stored?</strong><br />
      All brew logs and beans are stored locally on your device. Nothing is sent to external servers.
    </p>

    <p class="mb-10 text-base leading-relaxed">
      <strong>Can I export my data?</strong><br />
      Export is not currently supported but is planned for a future update.
    </p>

  </div>





  <div class="mt-auto flex pb-4 justify-end">
    <div class="text-right">
      <h2 class="mb-2 text-lg font-semibold uppercase tracking-wide">
        Contact
      </h2>

      <p class="text-base">
        <a href="mailto:soohwandev@gmail.com">soohwandev@gmail.com</a>
      </p>
    </div>

</BaseLayout>
